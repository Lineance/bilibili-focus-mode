{
  "manifest_version": 3,
  "name": "Bilibili Focus Mode",
  "version": "0.0.4",
  "description": "Intentional time management extension for Bilibili",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://*.bilibili.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.bilibili.com/*"
      ],
      "js": ["src/content/index.tsx"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "src/manager/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/manager/index.html", "assets/*", "src/popup/index.html"],
      "matches": ["https://*.bilibili.com/*"]
    }
  ]
}
