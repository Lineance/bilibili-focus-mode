# Chromium 扩展监控工具配置文件

[monitor]
# 监控检查间隔（秒）
check_interval = 1
# 延迟终止时间（秒）
kill_delay = 5
# 是否启用监控
enabled = true
# 是否显示控制台窗口（Windows）
show_console = true

[extension]
# 要监控的扩展 ID 列表
# 注意：需要替换为实际的 bilibili-blocker 扩展 ID
target_extensions = ["your-bilibili-blocker-extension-id-here"]
# 扩展名称（用于日志）
extension_name = "bilibili-blocker"

[chromium]
# Chromium 用户数据目录路径（支持多个）
# 留空则自动检测
# Windows 示例:
# user_data_dirs = [
#     "C:\\Users\\YourUsername\\AppData\\Local\\Chromium\\User Data",
#     "C:\\Users\\YourUsername\\AppData\\Local\\Google\\Chrome\\User Data"
# ]
user_data_dirs = []
# 要监控的进程名称
process_names = ["chromium.exe", "chrome.exe"]

[tray]
# 是否显示系统托盘
enabled = true
# 托盘图标路径（可选，留空使用内置图标）
icon_path = ""

[logging]
# 日志级别：trace, debug, info, warn, error
level = "info"
# 日志文件路径
file_path = "logs/chromium-monitor.log"
# 日志文件大小（MB）
max_size = 10
# 保留的日志文件数量
max_files = 5

[performance]
# CPU 使用率限制（百分比）
cpu_limit = 5
# 内存使用限制（MB）
memory_limit = 50
