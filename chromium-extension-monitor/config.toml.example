# Chromium 扩展监控工具配置文件

[monitor]
# 监控检查间隔（秒）
check_interval = 1
# 延迟终止时间（秒）
kill_delay = 5
# 是否启用监控
enabled = true
# 是否显示控制台窗口（Windows）
show_console = true

[extension]
# 要监控的扩展 ID 列表（精确匹配）
# 注意：需要替换为实际的 bilibili-blocker 扩展 ID
target_extensions = ["your-bilibili-blocker-extension-id-here"]

# 扩展名称关键字（模糊匹配）
# 对于未打包扩展，主要依靠名称匹配
extension_name_keywords = ["bilibili", "focus"]

# 匹配模式："exact" (精确) | "fuzzy" (模糊) | "mixed" (混合)
# 对于未打包扩展，建议使用 "fuzzy" 或 "mixed"
match_mode = "mixed"

# 要扫描的 Profile 列表（留空则扫描所有）
profiles = []

# 扩展名称（用于日志）
extension_name = "bilibili-blocker"

# 未打包扩展的路径列表（手动指定加载的扩展）
# 如果你的扩展是未打包加载的，在这里指定路径
unpacked_extensions_paths = [
]

[chromium]
# Chromium 用户数据目录路径（支持多个）
# 留空则自动检测
# Windows 示例:
# user_data_dirs = [
#     "C:\\Users\\YourUsername\\AppData\\Local\\Chromium\\User Data",
#     "C:\\Users\\YourUsername\\AppData\\Local\\Google\\Chrome\\User Data"
# ]
user_data_dirs = []
# 要监控的进程名称
process_names = ["chromium.exe", "chrome.exe"]
# 只在 Chrome 运行时扫描
scan_only_when_running = true
# Chrome 未运行时的检查间隔（秒）
idle_check_interval = 5

[logging]
# 日志级别：trace, debug, info, warn, error
level = "info"
# 日志文件路径
file_path = "logs/chromium-monitor.log"
# 日志文件大小（MB）
max_size = 10
# 保留的日志文件数量
max_files = 5

[performance]
# CPU 使用率限制（百分比）
cpu_limit = 5
# 内存使用限制（MB）
memory_limit = 50
